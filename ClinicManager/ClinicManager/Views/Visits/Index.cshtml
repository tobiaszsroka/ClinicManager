@model IEnumerable<ClinicManager.Models.Visit>
@{
    ViewData["Title"] = "Harmonogram Wizyt";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Harmonogram Wizyt</h2>
    @if (User.IsInRole("Admin") || User.IsInRole("Rejestratorka"))
    {
        <a asp-action="Create" class="btn btn-primary">Nowa wizyta</a>
    }
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Data wizyty</th>
                    <th>Pacjent</th>
                    <th>Lekarz</th>
                    <th>Status</th>
                    <th class="text-end">Akcje</th>
                </tr>
            </thead>
            <tbody>
                @if(!Model.Any()) {
                    <tr><td colspan="5" class="text-center text-muted py-3">Brak zaplanowanych wizyt.</td></tr>
                }
                @foreach (var item in Model) {
                <tr>
                    <td class="align-middle fw-bold">@item.ScheduledDate.ToString("g")</td>
                    <td class="align-middle">@item.Patient?.FirstName @item.Patient?.LastName</td>
                    <td class="align-middle">@item.Doctor?.Email</td>
                    <td class="align-middle">
                        @switch (item.Status)
                        {
                            case ClinicManager.Models.VisitStatus.Scheduled:
                                <span class="badge bg-warning text-dark">Zaplanowana</span>
                                break;
                            case ClinicManager.Models.VisitStatus.InProgress:
                                <span class="badge bg-info text-dark">W trakcie</span>
                                break;
                            case ClinicManager.Models.VisitStatus.Completed:
                                <span class="badge bg-success">Zakończona</span>
                                break;
                            case ClinicManager.Models.VisitStatus.Cancelled:
                                <span class="badge bg-danger">Anulowana</span>
                                break;
                        }
                    </td>
                    <td class="align-middle text-end">
                        <div class="btn-group">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edytuj</a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Szczegóły</a>
                            @if (User.IsInRole("Admin") || User.IsInRole("Rejestratorka"))
                            {
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Usuń</a>
                            }
                        </div>
                    </td>
                </tr>
                }
            </tbody>
        </table>
    </div>
</div>
