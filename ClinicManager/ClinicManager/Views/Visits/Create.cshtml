@model ClinicManager.Models.Visit
@{ ViewData["Title"] = "Nowa Wizyta"; }
<div class="mb-4">
    <h2>Nowa wizyta</h2>
    <p class="text-muted">Utwórz nową wizytę wybierając pacjenta, lekarza oraz datę.</p>
</div>

<div class="card shadow-sm max-w-lg">
    <div class="card-body">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            
            <div class="mb-3">
                <label asp-for="ScheduledDate" class="form-label">Data i godzina</label>
                <input asp-for="ScheduledDate" class="form-control" type="datetime-local" value="@Model.ScheduledDate.ToString("yyyy-MM-ddTHH:mm")" min="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                <span asp-validation-for="ScheduledDate" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="PatientId" class="form-label">Pacjent</label>
                <select asp-for="PatientId" class="form-select" asp-items="ViewBag.PatientId"></select>
            </div>
            
            <div class="mb-3">
                <label asp-for="AssignedDoctorId" class="form-label">Lekarz prowadzący</label>
                <select asp-for="AssignedDoctorId" class="form-select" asp-items="ViewBag.AssignedDoctorId"></select>
            </div>
            
            <div class="mb-3">
                <label asp-for="Status" class="form-label">Status</label>
                <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<ClinicManager.Models.VisitStatus>()"></select>
            </div>
            
            <div class="d-flex justify-content-between mt-4">
                <a asp-action="Index" class="btn btn-secondary">Anuluj</a>
                <button type="submit" class="btn btn-primary px-4">Zaplanuj wizytę</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
