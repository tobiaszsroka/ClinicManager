@model ClinicManager.Models.Visit
@{
    ViewData["Title"] = "Szczegóły Wizyty";
    var procedureCost = Model.Procedures?.Sum(p => p.FinalCost) ?? 0;
    var medicationCost = Model.PrescribedMedications?.Sum(p => p.TotalCost) ?? 0;
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var canPrescribe = User.IsInRole("Admin") ||
        (User.IsInRole("Lekarz") && Model.AssignedDoctorId == currentUserId);
}

<div class="mb-4">
    <h2>Szczegóły wizyty</h2>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<div class="card shadow-sm max-w-lg mb-4">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">Data i godzina</dt>
            <dd class="col-sm-8">@Model.ScheduledDate.ToString("g")</dd>
            
            <dt class="col-sm-4">Status</dt>
            <dd class="col-sm-8">
                @switch (Model.Status)
                {
                    case ClinicManager.Models.VisitStatus.Scheduled:
                        <span class="badge bg-warning text-dark">Zaplanowana</span>
                        break;
                    case ClinicManager.Models.VisitStatus.InProgress:
                        <span class="badge bg-info text-dark">W trakcie</span>
                        break;
                    case ClinicManager.Models.VisitStatus.Completed:
                        <span class="badge bg-success">Zakończona</span>
                        break;
                    case ClinicManager.Models.VisitStatus.Cancelled:
                        <span class="badge bg-danger">Anulowana</span>
                        break;
                }
            </dd>

            <dt class="col-sm-4">Pacjent</dt>
            <dd class="col-sm-8"><a asp-controller="Patients" asp-action="Details" asp-route-id="@Model.PatientId">@Model.Patient?.FirstName @Model.Patient?.LastName</a></dd>
            
            <dt class="col-sm-4">Lekarz</dt>
            <dd class="col-sm-8">@Model.Doctor?.Email</dd>
        </dl>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-white">
        <h4 class="mb-0">Wykonane procedury i koszty</h4>
    </div>
    <div class="card-body">
        @if (Model.Procedures != null && Model.Procedures.Any())
        {
            <table class="table table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>Nazwa procedury</th>
                        <th>Opis</th>
                        <th>Cena bazowa</th>
                        <th>Zniżka</th>
                        <th>Koszt końcowy</th>
                        <th>Akcje</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var proc in Model.Procedures)
                    {
                        <tr>
                            <td>@proc.Name</td>
                            <td>@proc.Description</td>
                            <td>@proc.BaseCost.ToString("c")</td>
                            <td>@proc.Discount.ToString("c")</td>
                            <td class="fw-bold">@proc.FinalCost.ToString("c")</td>
                            <td>
                                @if (Model.Status != ClinicManager.Models.VisitStatus.Completed && Model.Status != ClinicManager.Models.VisitStatus.Cancelled)
                                {
                                    <form asp-action="DeleteProcedure" method="post" class="d-inline">
                                        <input type="hidden" name="procedureId" value="@proc.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Usuń</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <th colspan="4" class="text-end">Koszt procedur:</th>
                        <th colspan="2" class="fs-5 text-success">@procedureCost.ToString("c")</th>
                    </tr>
                </tfoot>
            </table>
        }
        else
        {
            <p class="text-muted">Brak przypisanych procedur do tej wizyty.</p>
        }

        @if (Model.Status != ClinicManager.Models.VisitStatus.Completed && Model.Status != ClinicManager.Models.VisitStatus.Cancelled)
        {
            <div class="mt-4 border-top pt-3">
                <h5>Dodaj nową procedurę</h5>
                <form asp-action="AddProcedure" method="post" class="row g-3">
                    <input type="hidden" name="visitId" value="@Model.Id" />
                    
                    <div class="col-md-4">
                        <label class="form-label">Nazwa (np. EKG)</label>
                        <input type="text" name="name" class="form-control" required maxlength="100" />
                    </div>
                    
                    <div class="col-md-4">
                        <label class="form-label">Opis (opcjonalnie)</label>
                        <input type="text" name="description" class="form-control" maxlength="500" />
                    </div>
                    
                    <div class="col-md-2">
                        <label class="form-label">Koszt (PLN)</label>
                        <input type="number" name="baseCost" class="form-control" step="0.01" min="0" required />
                    </div>
                    
                    <div class="col-md-2">
                        <label class="form-label">Zniżka (PLN)</label>
                        <input type="number" name="discount" class="form-control" step="0.01" min="0" value="0" />
                    </div>
                    
                    <div class="col-12 text-end">
                        <button type="submit" class="btn btn-success">Dodaj procedurę</button>
                    </div>
                </form>
            </div>
        }
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-white">
        <h4 class="mb-0">Recepta i koszty leków</h4>
    </div>
    <div class="card-body">
        @if (Model.PrescribedMedications != null && Model.PrescribedMedications.Any())
        {
            <div class="table-responsive">
                <table class="table table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Lek</th>
                            <th>Dawkowanie</th>
                            <th>Ilość</th>
                            <th>Cena jednostkowa</th>
                            <th>Koszt</th>
                            <th>Akcje</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var prescription in Model.PrescribedMedications)
                        {
                            <tr>
                                <td>@prescription.Medication?.Name</td>
                                <td>@prescription.Dosage</td>
                                <td>@prescription.Quantity</td>
                                <td>@prescription.UnitPriceAtPrescription.ToString("c")</td>
                                <td class="fw-bold">@prescription.TotalCost.ToString("c")</td>
                                <td>
                                    @if (canPrescribe && Model.Status != ClinicManager.Models.VisitStatus.Completed && Model.Status != ClinicManager.Models.VisitStatus.Cancelled)
                                    {
                                        <form asp-action="DeletePrescription" method="post" class="d-inline">
                                            <input type="hidden" name="prescriptionId" value="@prescription.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Usuń</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <th colspan="4" class="text-end">Koszt leków:</th>
                            <th colspan="2" class="fs-5 text-success">@medicationCost.ToString("c")</th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted">Nie przepisano jeszcze żadnych leków.</p>
        }

        @if (canPrescribe && Model.Status != ClinicManager.Models.VisitStatus.Completed && Model.Status != ClinicManager.Models.VisitStatus.Cancelled)
        {
            <div class="mt-4 border-top pt-3">
                <h5>Dodaj lek do recepty</h5>
                @if (ViewBag.HasMedications == true)
                {
                    <form asp-action="AddPrescription" method="post" class="row g-3">
                        <input type="hidden" name="visitId" value="@Model.Id" />
                        <div class="col-md-4">
                            <label class="form-label">Lek</label>
                            <select name="medicationId" class="form-select" asp-items="ViewBag.MedicationId" required></select>
                        </div>
                        <div class="col-md-5">
                            <label class="form-label">Dawkowanie</label>
                            <input type="text" name="dosage" class="form-control" maxlength="100" placeholder="np. 1 tabletka 2 razy dziennie" required />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Ilość</label>
                            <input type="number" name="quantity" class="form-control" min="1" max="1000" value="1" required />
                        </div>
                        <div class="col-md-1 d-flex align-items-end">
                            <button type="submit" class="btn btn-success">Dodaj</button>
                        </div>
                    </form>
                }
                else
                {
                    <div class="alert alert-warning mb-0">Katalog leków jest pusty. Admin lub Rejestratorka musi najpierw dodać lek.</div>
                }
            </div>
        }
    </div>
</div>

<div class="card border-success shadow-sm mb-4">
    <div class="card-body d-flex justify-content-between align-items-center">
        <span class="fs-5 fw-bold">Łączny koszt wizyty</span>
        <span class="fs-4 fw-bold text-success">@((procedureCost + medicationCost).ToString("c"))</span>
    </div>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary">Edytuj wizytę</a>
    <a asp-action="Index" class="btn btn-secondary">Wróć do listy</a>
</div>
