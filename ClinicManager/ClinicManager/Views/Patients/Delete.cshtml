@model ClinicManager.Models.Patient

@{
    ViewData["Title"] = "Usuń pacjenta";
}

<div class="mb-4">
    <h2 class="text-danger">Usuń pacjenta</h2>
    <p class="text-muted">Czy na pewno chcesz usunąć poniższego pacjenta? Ta operacja jest nieodwracalna.</p>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm border-danger">
            <div class="card-body">
                <h5 class="card-title mb-3">@Model.FirstName @Model.LastName</h5>
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">PESEL</dt>
                    <dd class="col-sm-8">@Model.Pesel</dd>
                    
                    <dt class="col-sm-4 text-muted">ID w bazie</dt>
                    <dd class="col-sm-8">@Model.Id</dd>
                </dl>
            </div>
            <div class="card-footer bg-white d-flex justify-content-between align-items-center">
                <a asp-action="Index" class="btn btn-outline-secondary">Anuluj i powróć</a>
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger px-4">Usuń trwale</button>
                </form>
            </div>
        </div>
    </div>
</div>
