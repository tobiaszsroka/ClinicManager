@model ClinicManager.Models.Patient

@{
    ViewData["Title"] = "Szczegóły pacjenta";
}

<div class="mb-4">
    <h2>Karta pacjenta</h2>
    <p class="text-muted">Szczegółowe informacje o pacjencie.</p>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0 pt-1">@Model.FirstName @Model.LastName</h5>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">ID Systemowe</dt>
                    <dd class="col-sm-8">@Model.Id</dd>

                    <dt class="col-sm-4 text-muted">PESEL</dt>
                    <dd class="col-sm-8 fw-bold">@Model.Pesel</dd>

                    <dt class="col-sm-4 text-muted">Numer ubezpieczenia</dt>
                    <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.InsuranceNumber) ? "Brak wpisu" : Model.InsuranceNumber)</dd>

                    <dt class="col-sm-4 text-muted">Numer telefonu</dt>
                    <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.PhoneNumber) ? "Brak wpisu" : Model.PhoneNumber)</dd>

                    <dt class="col-sm-4 text-muted">Adres E-mail</dt>
                    <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.Email) ? "Brak wpisu" : Model.Email)</dd>
                </dl>
            </div>
            <div class="card-footer bg-white d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-outline-secondary">Powrót do listy</a>
                <div>
                    <a asp-controller="MedicalRecords" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-info me-2 text-white">Przejdź do kartoteki</a>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary px-4">Edytuj</a>
                </div>
            </div>
        </div>

        <div class="mt-5">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4>Historia i Planowane Wizyty</h4>
                @if (User.IsInRole("Admin") || User.IsInRole("Rejestratorka"))
                {
                    <a asp-controller="Visits" asp-action="Create" asp-route-patientId="@Model.Id" class="btn btn-sm btn-success">
                        Umów nową wizytę
                    </a>
                }
            </div>
            <div class="card shadow-sm">
                <div class="card-body p-0">
                    <table class="table table-striped table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Data</th>
                                <th>Status</th>
                                <th>Całkowity Koszt</th>
                                <th class="text-end">Akcje</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Visits == null || !Model.Visits.Any())
                            {
                                <tr><td colspan="4" class="text-center text-muted py-3">Ten pacjent nie ma żadnych zapisanych wizyt.</td></tr>
                            }
                            else
                            {
                                @foreach(var visit in Model.Visits.OrderByDescending(v => v.ScheduledDate))
                                {
                                    <tr>
                                        <td class="align-middle fw-bold">@visit.ScheduledDate.ToString("g")</td>
                                        <td class="align-middle">
                                            @switch (visit.Status)
                                            {
                                                case ClinicManager.Models.VisitStatus.Scheduled:
                                                    <span class="badge bg-warning text-dark">Zaplanowana</span>
                                                    break;
                                                case ClinicManager.Models.VisitStatus.InProgress:
                                                    <span class="badge bg-info text-dark">W trakcie</span>
                                                    break;
                                                case ClinicManager.Models.VisitStatus.Completed:
                                                    <span class="badge bg-success">Zakończona</span>
                                                    break;
                                                case ClinicManager.Models.VisitStatus.Cancelled:
                                                    <span class="badge bg-danger">Anulowana</span>
                                                    break;
                                            }
                                        </td>
                                        <td class="align-middle">
                                            @(visit.Procedures?.Any() == true ? visit.Procedures.Sum(p => p.FinalCost).ToString("c") : "0,00 zł")
                                        </td>
                                        <td class="align-middle text-end">
                                            <a asp-controller="Visits" asp-action="Details" asp-route-id="@visit.Id" class="btn btn-sm btn-outline-info">Pokaż szczegóły</a>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
